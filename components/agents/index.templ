package agents

import (
	"go-huginn-clone/components"
	"go-huginn-clone/components/layouts"
	"go-huginn-clone/models"
)

templ Index(props layouts.PageProps, agentList []models.Agent, pagination models.Pagination, sortCol, sortDir string, service *models.Service, showDisabled bool) {
	@layouts.Base(props) {
		<div class="container">
			<div class="row">
				<div class="col-md-12">
					<div class="page-header">
						<h2>Your Agents</h2>
						if service != nil {
							<p class="text-muted">
								Filtered by service:
								@components.ServiceLabel(service)
							</p>
						}
					</div>
					@Table(agentList, pagination, sortCol, sortDir, "/agents")
					<br/>
					<div class="btn-group">
						<a href="/agents/new" class="btn btn-default visibility-enabler">
							<span class="glyphicon glyphicon-plus"></span> New Agent
						</a>
						<a href="/agents/propagate" class="btn btn-default" data-method="post">
							<span class="glyphicon glyphicon-refresh"></span> Run event propagation
						</a>
						<a href="/diagram" class="btn btn-default">
							<span class="glyphicon glyphicon-random"></span> View diagram
						</a>
						<a href="/agents/toggle_visibility" class="btn btn-default visibility-enabler" data-method="put">
							<span class="glyphicon glyphicon-adjust"></span>
							if showDisabled {
								Hide disabled agents
							} else {
								Show disabled agents
							}
						</a>
					</div>
				</div>
			</div>
		</div>
	}
}
