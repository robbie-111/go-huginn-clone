package agents

import (
	"encoding/json"
	"fmt"
	"go-huginn-clone/components"
	"go-huginn-clone/components/layouts"
	"go-huginn-clone/models"
)

templ DryRunIndex(props layouts.PageProps, agent models.Agent, recentEvents []models.Event, withEventMode string) {
	@layouts.Base(props) {
		<div class="container">
			<div class="row">
				<div class="col-md-12">
					<h3>Dry Run: { agent.Name }</h3>
					if len(recentEvents) > 0 {
						<h5>Recently received events:</h5>
						for _, event := range recentEvents {
							<a href="#" class="dry-run-event-sample" data-payload={ eventPayloadJSON(event) }>
								<pre>{ components.Truncate(eventPayloadJSON(event), 90) }</pre>
							</a>
						}
					}
					<h5>
						Event to send
						if withEventMode == "maybe" {
							(Optional)
						}
					</h5>
					<form class="dry-run-form" method="POST" action={ dryRunFormAction(agent) }>
						<input type="hidden" name="csrf_token" value="mock-csrf-token"/>
						<input type="hidden" name="with_event_mode" value={ withEventMode }/>
						<div class="form-group">
							<textarea rows="10" name="event" class="payload-editor form-control" data-height="200" style="font-family:monospace;">
								{}
							</textarea>
						</div>
						<div class="form-group">
							<input value="Dry Run" class="btn btn-primary" type="submit"/>
						</div>
					</form>
				</div>
			</div>
		</div>
	}
}

templ DryRunCreate(props layouts.PageProps, agent models.Agent, result models.DryRunResult) {
	@layouts.Base(props) {
		<div class="container">
			<div class="row">
				<div class="col-md-12">
					<h3>Dry Run Result: { agent.Name }</h3>
					<!-- Nav tabs -->
					<ul id="resultTabs" class="nav nav-tabs agent-dry-run-tabs" role="tablist">
						<li role="presentation" class={ dryRunTabClass(result, true) }>
							<a href="#tabEvents" aria-controls="tabEvents" role="tab" data-toggle="tab">Events</a>
						</li>
						<li role="presentation" class={ dryRunTabClass(result, false) }>
							<a href="#tabLog" aria-controls="tabLog" role="tab" data-toggle="tab">Log</a>
						</li>
						<li role="presentation">
							<a href="#tabMemory" aria-controls="tabMemory" role="tab" data-toggle="tab">Memory</a>
						</li>
					</ul>
					<!-- Tab panes -->
					<div class="tab-content">
						<div role="tabpanel" class={ "tab-pane " + dryRunTabClass(result, true) } id="tabEvents">
							<pre class="agent-dry-run-events">{ components.PrettyJSON(result.Events) }</pre>
						</div>
						<div role="tabpanel" class={ "tab-pane " + dryRunTabClass(result, false) } id="tabLog">
							<pre><small class="agent-dry-run-log">{ result.Log }</small></pre>
						</div>
						<div role="tabpanel" class="tab-pane" id="tabMemory">
							<pre class="agent-dry-run-memory">{ components.PrettyJSON(result.Memory) }</pre>
						</div>
					</div>
					<br/>
					<a href={ templ.SafeURL(dryRunFormAction(agent)) } class="btn btn-default">Run Again</a>
					<a href={ templ.SafeURL("/agents/" + agentIDStr(agent)) } class="btn btn-default">Back to Agent</a>
				</div>
			</div>
		</div>
	}
}

func dryRunTabClass(result models.DryRunResult, eventsTab bool) string {
	hasEvents := len(result.Events) > 0
	if eventsTab {
		if hasEvents {
			return "active"
		}
		return ""
	}
	if !hasEvents {
		return "active"
	}
	return ""
}

func eventPayloadJSON(event models.Event) string {
	b, _ := json.MarshalIndent(event.Payload, "", "  ")
	return string(b)
}

func dryRunFormAction(agent models.Agent) string {
	return fmt.Sprintf("/agents/%d/dry_runs", agent.ID)
}

func agentIDStr(agent models.Agent) string {
	return fmt.Sprintf("%d", agent.ID)
}


